PORT=6031
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/hbat-nathri
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://127.0.0.1:5175, 

# Used once to create the first admin if no admin exists.
ADMIN_SETUP_KEY=change-this-bootstrap-key

# Admin credentials used by:
# - npm run seed:admin
# - npm run create:admin-file
ADMIN_EMAIL=admin@hbat-nathri.local
ADMIN_PASSWORD=your-strong-password

# Firebase Admin SDK.
# Option A: path to service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Option B: base64 encoded service account JSON. Overrides GOOGLE_APPLICATION_CREDENTIALS when set.
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
